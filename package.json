    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.0.7",
    "postcss": "^8.4.49",
